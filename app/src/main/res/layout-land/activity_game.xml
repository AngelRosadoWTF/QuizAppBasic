<?xml version="1.0" encoding="utf-8"?>
<!-- Guardar en: res/layout-land/activity_game.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp">

    <!-- Contador (pregunta X / total) -->
    <TextView
        android:id="@+id/contador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1 / 5"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Pistas disponibles -->
    <TextView
        android:id="@+id/pista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pistas: 3"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Panel izquierdo: ícono de tema + pregunta -->
    <ImageView
        android:id="@+id/imgTheme"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:contentDescription="Tema"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/contador"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/layoutAnswers"/>

    <TextView
        android:id="@+id/tvQuestion"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="Texto de la pregunta"
        android:textSize="15sp"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/imgTheme"
        app:layout_constraintBottom_toTopOf="@id/btnHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/layoutAnswers"/>

    <!-- Botón de pista (panel izquierdo, abajo) -->
    <Button
        android:id="@+id/btnHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💡 PISTA"
        app:layout_constraintBottom_toTopOf="@id/navLayout"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- PREV / NEXT (panel izquierdo, esquina inferior) -->
    <LinearLayout
        android:id="@+id/navLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◀ PREV"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEXT ▶"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- Panel derecho: respuestas -->
    <LinearLayout
        android:id="@+id/layoutAnswers"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toBottomOf="@id/contador"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.50"
        app:layout_constraintStart_toEndOf="@id/tvQuestion">

        <Button
            android:id="@+id/btnAnswer1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Respuesta 1"
            android:textColor="@android:color/white"/>

        <Button
            android:id="@+id/btnAnswer2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Respuesta 2"
            android:textColor="@android:color/white"
            android:layout_marginTop="6dp"/>

        <Button
            android:id="@+id/btnAnswer3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Respuesta 3"
            android:textColor="@android:color/white"
            android:layout_marginTop="6dp"/>

        <Button
            android:id="@+id/btnAnswer4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Respuesta 4"
            android:textColor="@android:color/white"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>